<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>스터디룸 생성 - 코사모</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>

  <main class="app-main">
    <section class="mb-pr-24">
      <h1 class="text-24sb mb-pr-6">새 스터디룸 만들기</h1>
      <p class="text-slate-400 text-14m">함께 공부할 사람들을 초대할 스터디룸을 생성합니다.</p>
    </section>

    <% if (error) { %><div class="mb-pr-16 rounded-pr-10 border border-red-500/50 bg-red-900/30 px-pr-12 py-pr-10 text-14m text-red-300"><%= error %></div><% } %>

    <section class="card">
      <form action="/studyroom/new" method="POST" class="space-y-pr-16">
        <div>
          <label for="title" class="form-label">스터디룸 이름 <span class="text-red-400">*</span></label>
          <input type="text" id="title" name="title" required placeholder="예) Node.js 백엔드 스터디" class="input" value="<%= typeof title !== 'undefined' ? title : '' %>" />
        </div>

        <div>
          <label for="description" class="form-label">스터디룸 소개</label>
          <textarea id="description" name="description" rows="4" placeholder="스터디 소개를 작성해주세요." class="textarea"><%= typeof description !== 'undefined' ? description : '' %></textarea>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-pr-16">
          <div>
            <label for="maxMembers" class="form-label">최대 인원 수</label>
            <input type="number" id="maxMembers" name="maxMembers" min="2" max="50" value="<%= typeof maxMembers !== 'undefined' ? maxMembers : 10 %>" class="input" />
          </div>
          <div>
            <span class="form-label">공개 설정</span>
            <label class="inline-flex items-center mt-pr-6 cursor-pointer">
              <input type="checkbox" name="isPublic" class="mr-pr-8 rounded border-slate-600 bg-slate-900 text-b-primary focus:ring-b-primary" <%= typeof isPublic !== 'undefined' ? (isPublic ? 'checked' : '') : 'checked' %> />
              <span class="text-14m text-slate-300">공개 스터디룸</span>
            </label>
          </div>
        </div>

        <div class="flex items-center justify-end gap-pr-8 pt-pr-16 border-t border-slate-700">
          <a href="/" class="btn btn-secondary">취소</a>
          <button type="submit" class="btn btn-primary">스터디룸 생성하기</button>
        </div>
      </form>
    </section>
  </main>
</body>
</html>
