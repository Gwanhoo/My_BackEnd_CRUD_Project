<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>채팅방</title>
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>
  <main class="max-w-3xl mx-auto px-4 py-pr-32">
    <div class="surface overflow-hidden">
      <div class="flex items-center justify-between px-pr-20 py-pr-14 border-b border-slate-700 bg-slate-900">
        <button id="editRoomNameBtn" class="text-b-tertiary text-16sb">수정</button>
        <div class="flex-1 text-center"><span id="roomName" class="text-18sb text-white"><%= room.name || '채팅방' %></span></div>
        <a href="/chat/list" class="text-b-tertiary text-16sb">돌아가기 →</a>
      </div>

      <div id="chatBox" class="h-[400px] overflow-y-auto px-pr-16 py-pr-12 space-y-pr-10 bg-slate-900">
        <% if (messages && messages.length > 0) { %>
          <% messages.forEach(m => { %>
            <div class="flex <%= String(m.userId) === String(user._id) ? 'justify-end' : 'justify-start' %>">
              <div class="<%= String(m.userId) === String(user._id) ? 'bg-b-primary text-white' : 'bg-slate-700 text-slate-100' %> px-pr-12 py-pr-6 rounded-pr-10 max-w-[70%] break-words"><%= m.content %></div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <form id="chatForm" class="flex items-center gap-pr-10 border-t border-slate-700 px-pr-16 py-pr-12 bg-slate-900">
        <input id="msgInput" type="text" placeholder="메시지를 입력하세요..." class="input flex-1" autocomplete="off" />
        <button type="submit" class="btn btn-primary">보내기</button>
      </form>
    </div>
  </main>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = window.socket || io(); window.socket = socket;
    const roomId = "<%= room._id %>"; const myId = "<%= user._id %>";
    const chatBox = document.getElementById('chatBox'); const chatForm = document.getElementById('chatForm'); const msgInput = document.getElementById('msgInput');
    chatBox.scrollTop = chatBox.scrollHeight;
    if (socket.connected) { socket.emit('join-room', roomId); } else { socket.once('connect', () => { socket.emit('join-room', roomId); }); }
    socket.off('chat-message'); socket.on('chat-message', (data) => { addMessage(data); });
    chatForm.addEventListener('submit', (e) => { e.preventDefault(); const msg = msgInput.value.trim(); if (!msg) return; addMessage({ senderId: myId, message: msg }); socket.emit('chat-message', { roomId, senderId: myId, message: msg }); msgInput.value = ''; msgInput.focus(); });
    function addMessage(data) {
      const wrap = document.createElement('div'); const isMe = (String(data.senderId) === String(myId)); wrap.className = 'flex ' + (isMe ? 'justify-end' : 'justify-start');
      const bubble = document.createElement('div'); bubble.className = (isMe ? 'bg-b-primary text-white' : 'bg-slate-700 text-slate-100') + ' px-pr-10 py-pr-6 rounded-pr-10 max-w-[70%] break-words';
      bubble.textContent = data.message; wrap.appendChild(bubble); chatBox.appendChild(wrap); chatBox.scrollTop = chatBox.scrollHeight;
    }
  </script>

  <script>
    const editBtn = document.getElementById('editRoomNameBtn'); const roomNameSpan = document.getElementById('roomName');
    editBtn.addEventListener('click', () => {
      const newName = prompt('새 채팅방 이름을 입력하세요:', roomNameSpan.textContent); if (!newName) return;
      fetch('/chat/room/<%= room._id %>/rename', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name: newName }) })
      .then(res => res.json()).then(data => { if (data.ok) { roomNameSpan.textContent = newName; alert('채팅방 이름이 변경되었습니다.'); } else { alert('변경 실패'); } });
    });
  </script>
</body>
</html>
