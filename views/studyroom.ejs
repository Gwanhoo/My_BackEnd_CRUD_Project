<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title><%= room.title %> - 스터디룸</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>

  <main class="max-w-5xl mx-auto px-4 py-pr-24">
    <div class="flex items-center justify-between mb-pr-8">
      <h1 class="text-24sb"><%= room.title %></h1>
      <a href="/invite/search?roomId=<%= room._id %>" class="btn btn-primary">초대하기</a>
    </div>
    <p class="text-12m text-slate-400 mb-pr-12">스터디룸 ID: <%= room._id %></p>

    <div id="chat-log" class="surface h-[320px] overflow-y-auto p-pr-12 space-y-pr-4">
      <% chats.forEach(function(c) { %>
        <div>
          <strong class="text-slate-200"><%= String(c.userId) === String(user._id) ? "나" : c.userId %></strong>:
          <span class="text-slate-300"><%= c.content %></span>
        </div>
      <% }) %>
    </div>

    <form id="chat-form" class="mt-pr-12 flex gap-pr-8">
      <input id="chat-input" class="input flex-1" autocomplete="off" placeholder="메시지를 입력하세요" />
      <button type="submit" class="btn btn-primary">전송</button>
    </form>
  </main>

  <script src="/socket.io/socket.io.js"></script>
  <script>
    const socket = io();
    const roomId = "<%= room._id %>"; const myId = "<%= user._id %>";
    socket.emit('join-room', roomId);
    const form = document.getElementById('chat-form'); const input = document.getElementById('chat-input'); const log = document.getElementById('chat-log');
    form.addEventListener('submit', function (e) {
      e.preventDefault(); const text = input.value.trim(); if (!text) return;
      socket.emit('chat-message', { roomId, senderId: myId, message: text });
      const div = document.createElement('div'); div.innerHTML = "<strong class='text-slate-200'>나</strong>: <span class='text-slate-300'>" + text + "</span>";
      log.appendChild(div); log.scrollTop = log.scrollHeight; input.value = '';
    });
    socket.on('chat-message', function (data) {
      const div = document.createElement('div'); const name = (data.senderId === myId) ? "나" : data.senderId;
      div.innerHTML = "<strong class='text-slate-200'>" + name + "</strong>: <span class='text-slate-300'>" + data.message + "</span>";
      log.appendChild(div); log.scrollTop = log.scrollHeight;
    });
  </script>
</body>
</html>
