<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>검색 결과</title>
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>

  <main class="app-main">
    <form action="/search" method="GET" class="w-full max-w-pr-520 mx-auto flex items-center gap-pr-12 mb-pr-24">
      <input type="text" name="val" value="<%= (typeof q === 'string' ? q : '') %>" placeholder="검색어를 입력하세요..." class="input flex-1" autocomplete="off" />
      <button type="submit" class="btn btn-primary">검색</button>
    </form>

    <section class="mb-pr-16">
      <h1 class="text-24sb">검색어: <span class="text-b-tertiary">"<%= (typeof q === 'string' && q.trim() ? q.trim() : '—') %>"</span></h1>
      <p class="text-slate-400 mt-pr-4">총 <strong><%= Array.isArray(posts) ? posts.length : 0 %></strong>건</p>
    </section>

    <% if (!posts || posts.length === 0) { %>
      <div class="empty-state">
        <p>검색 결과가 없습니다.</p>
        <a href="/list" class="mt-pr-12 inline-block text-b-tertiary hover:underline">목록으로 돌아가기</a>
      </div>
    <% } else { %>
      <div class="table-wrap">
        <table class="table-ui">
          <thead><tr><th>제목</th><th>작성자</th><th>작성일</th><th class="w-16">수정</th><th class="w-16">삭제</th></tr></thead>
          <tbody>
            <% posts.forEach(function(post){ %>
              <tr>
                <td><a href="/detail/<%= post._id %>" class="hover:text-b-tertiary font-medium"><%= post.title %></a></td>
                <td><%= post.authorName || '알 수 없음' %></td>
                <td><% if (post.createdAt) { %><%= new Date(post.createdAt).toLocaleDateString() %><% } %></td>
                <td class="text-center"><% const 내아이디 = user?._id ? String(user._id) : null; if (isLogin && String(post.authorId) === 내아이디) { %><a href="/edit/<%= post._id %>" class="text-b-tertiary hover:underline">수정</a><% } %></td>
                <td class="text-center"><% if (isLogin && String(post.authorId) === 내아이디) { %><button type="button" data-id="<%= post._id %>" class="delete text-red-400 hover:underline">삭제</button><% } %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </main>

  <script>
    document.querySelectorAll('.delete').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = btn.dataset.id;
        if (!confirm('정말 삭제하시겠습니까?')) return;
        try {
          const res = await fetch(`/delete?docId=${encodeURIComponent(id)}`, { method: 'DELETE' });
          const msg = await res.text();
          alert(msg);
          btn.closest('tr')?.remove();
        } catch (e) {
          console.error(e);
          alert('삭제 중 오류가 발생했습니다.');
        }
      });
    });
  </script>
</body>
</html>
