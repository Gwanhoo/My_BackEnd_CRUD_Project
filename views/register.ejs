<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>회원가입</title>
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>

  <main class="min-h-[calc(100dvh-64px)] flex items-center justify-center px-4 py-pr-24">
    <form class="form max-w-md" action="/register" method="POST">
      <h2 class="text-24sb mb-pr-24">회원가입</h2>

      <label class="form-label">아이디</label>
      <input name="username" class="input" autocomplete="username" required />

      <label class="form-label mt-pr-16">비밀번호</label>
      <input name="password" type="password" class="input" autocomplete="new-password" required />

      <button type="submit" class="btn btn-primary w-full mt-pr-24">회원가입</button>
    </form>
  </main>
</body>
</html>
