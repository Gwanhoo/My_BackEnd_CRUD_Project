<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>초대 목록</title>
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>
  <main class="max-w-3xl mx-auto px-4 py-pr-32">
    <h1 class="text-24sb mb-pr-20">받은 초대</h1>
    <ul class="surface divide-y divide-slate-700">
      <% invites.forEach(inv => { %>
        <li class="p-pr-12">
          <div class="text-14m text-slate-300">스터디룸: <%= inv.roomId %></div>
          <div class="text-14m text-slate-400 mt-pr-4">초대한 사람: <%= inv.from %></div>
          <form method="POST" action="/invite/accept" class="mt-pr-10">
            <input type="hidden" name="inviteId" value="<%= inv._id %>" />
            <button class="btn btn-primary">수락하기</button>
          </form>
        </li>
      <% }) %>
    </ul>
  </main>
</body>
</html>
