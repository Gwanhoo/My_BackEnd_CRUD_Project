<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <title>프로필 등록/수정</title>
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>

  <main class="max-w-3xl mx-auto px-4 py-pr-32">
    <h1 class="text-24sb mb-pr-20">프로필 등록 / 수정</h1>

    <form action="/profile/edit" method="POST" class="card space-y-pr-16">
      <div><label class="form-label">이름</label><input name="name" value="<%= profile?.name || me.username %>" class="input"></div>
      <div><label class="form-label">나이</label><input name="age" type="number" value="<%= profile?.age || '' %>" class="input"></div>
      <div><label class="form-label">학교</label><input name="school" value="<%= profile?.school || '' %>" class="input"></div>
      <div>
        <label class="form-label">기술 스택</label>
        <input name="stacks" placeholder="React, Node.js, MongoDB" value="<%= profile?.stacks ? profile.stacks.join(', ') : '' %>" class="input">
        <p class="text-12m text-slate-400 mt-pr-4">쉼표(,)로 구분해서 입력</p>
      </div>
      <div><label class="form-label">취미</label><input name="hobby" value="<%= profile?.hobby || '' %>" class="input"></div>
      <div><label class="form-label">소개글</label><textarea name="intro" rows="4" class="textarea"><%= profile?.intro || '' %></textarea></div>

      <div class="pt-pr-10 flex justify-end gap-pr-8">
        <a href="/mypage" class="btn btn-secondary">돌아가기</a>
        <button type="submit" class="btn btn-primary">저장</button>
      </div>
    </form>
  </main>
</body>
</html>
