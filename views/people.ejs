<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>사람 찾기 - 코사모</title>
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>

  <main class="app-main">
    <div class="flex items-center justify-between mb-pr-20">
      <h1 class="text-24sb">가입한 사람들</h1>
      <p class="text-14m text-slate-400">조건 검색은 나중에 붙일 수 있어요.</p>
    </div>

    <% if (people.length === 0) { %>
      <p class="empty-state py-pr-32">아직 등록된 프로필이 없습니다.</p>
    <% } else { %>
      <div class="grid tamo:grid-cols-2 gap-pr-16">
        <% people.forEach(function(person) { %>
          <article class="card flex flex-col gap-pr-10">
            <div class="flex items-center gap-pr-10">
              <div class="w-pr-40 h-pr-40 rounded-full bg-slate-700 flex items-center justify-center text-16sb text-b-tertiary"><%= person.name ? person.name.slice(0,1) : "유" %></div>
              <div>
                <h2 class="text-16sb text-white"><%= person.name || '이름 없음' %></h2>
                <p class="text-14m text-slate-400"><%= person.role || '관심 분야 미입력' %></p>
              </div>
            </div>
            <% if (person.intro) { %><p class="text-14m text-slate-300 leading-relaxed"><%= person.intro %></p><% } %>
            <% if (person.stacks && person.stacks.length > 0) { %>
              <div class="flex flex-wrap gap-pr-6">
                <% person.stacks.forEach(function(stack) { %><span class="badge"><%= stack %></span><% }) %>
              </div>
            <% } %>
            <% if (isLogin && String(person.userId) !== String(user._id)) { %>
              <div class="mt-auto flex justify-end"><a href="/chat/request?writerId=<%= person.userId %>" class="btn btn-primary">채팅하기</a></div>
            <% } %>
          </article>
        <% }) %>
      </div>
    <% } %>
  </main>
</body>
</html>
