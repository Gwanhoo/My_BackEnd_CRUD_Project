<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>스터디룸 목록</title>
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>

  <main class="max-w-4xl mx-auto px-4 py-pr-32">
    <h1 class="text-24sb mb-pr-24">내 스터디룸 목록</h1>
    <% if (rooms.length === 0) { %>
      <div class="empty-state py-pr-24">아직 참여 중인 스터디룸이 없습니다.<br><a href="/studyroom/new" class="text-b-tertiary hover:underline">새 스터디룸 만들기</a></div>
    <% } %>

    <div class="grid gap-pr-12">
      <% rooms.forEach(room => { %>
        <div class="card p-pr-16 flex justify-between items-center">
          <div>
            <div class="text-18sb text-white"><%= room.title %></div>
            <div class="text-14m text-slate-400">방장: <%= room.owner %> • 멤버: <%= room.member.length %>명</div>
          </div>
          <a href="/studyroom/<%= room._id %>" class="btn btn-primary">입장하기</a>
        </div>
      <% }) %>
    </div>
  </main>
</body>
</html>
