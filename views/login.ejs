<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>로그인</title>
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>

  <main class="min-h-[calc(100dvh-64px)] flex items-center justify-center px-4 py-pr-24">
    <form action="/login" method="POST" class="form max-w-md">
      <h2 class="text-24sb mb-pr-24 text-center">로그인</h2>

      <label class="form-label">아이디</label>
      <input name="username" class="input" autocomplete="username" />

      <label class="form-label mt-pr-16">비밀번호</label>
      <input name="password" type="password" class="input" autocomplete="current-password" />

      <button type="submit" class="btn btn-primary w-full mt-pr-20">로그인</button>

      <div class="relative my-pr-20">
        <div class="border-t border-slate-700"></div>
        <span class="absolute -top-[10px] left-1/2 -translate-x-1/2 bg-slate-900 px-pr-8 text-12m text-slate-400">또는</span>
      </div>

      <a href="/auth/kakao" class="btn btn-secondary w-full !h-auto py-pr-8">
        <img src="kakao_logo.png" alt="카카오 로그인" class="w-pr-240 h-[45px] object-contain" />
      </a>

      <p class="text-center text-14m text-slate-400 mt-pr-16">
        아직 계정이 없나요?
        <a href="/register" class="text-b-tertiary hover:text-b-primary">회원가입</a>
      </p>
    </form>
  </main>
</body>
</html>
