<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>글 수정</title>
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>
  <main class="app-main">
    <form class="form" action="/edit/<%= post._id %>" method="POST">
      <h2 class="text-24sb mb-pr-16">수정하기</h2>
      <label class="form-label">제목</label>
      <input name="title" class="input" value="<%= post.title %>" />

      <label class="form-label mt-pr-16">내용</label>
      <textarea name="content" class="textarea"><%= post.content %></textarea>

      <button type="submit" class="btn btn-primary w-full mt-pr-24">저장</button>
    </form>
  </main>
</body>
</html>
