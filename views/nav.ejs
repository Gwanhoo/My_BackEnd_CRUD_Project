<header class="border-b border-slate-700/80 bg-slate-950/90 backdrop-blur">
  <nav class="max-w-5xl mx-auto flex items-center justify-between px-4 py-pr-12">
    <a href="/" class="text-20sb text-white hover:text-b-tertiary transition">코사모</a>
    <div class="flex items-center gap-pr-8">
      <% if (!isLogin) { %>
        <a href="/login" class="link">로그인</a>
        <a href="/register" class="btn btn-primary">회원가입</a>
      <% } else { %>
        <a href="/write" class="btn btn-ghost">글쓰기</a>
        <a href="/studyroom/new" class="btn btn-ghost">스터디룸 생성</a>
        <a href="/studyroom/list" class="btn btn-ghost">스터디룸 목록</a>
        <a href="/invite/list" class="btn btn-ghost">알림</a>
        <a href="/mypage" class="btn btn-primary"><%= user.username %> 마이페이지</a>
        <a href="/logout" class="btn btn-danger">로그아웃</a>
      <% } %>
    </div>
  </nav>
</header>
