<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>채팅방 목록</title>
  <link rel="stylesheet" href="/output.css?v=<%= Date.now() %>">
</head>
<body class="app-shell">
  <%- include('nav.ejs') %>

  <main class="max-w-3xl mx-auto px-4 py-pr-32">
    <h1 class="text-24sb mb-pr-24">채팅방 목록</h1>
    <% if (chatrooms.length === 0) { %>
      <p class="empty-state py-pr-32">아직 생성된 채팅방이 없습니다.</p>
    <% } else { %>
      <ul class="space-y-pr-12">
        <% chatrooms.forEach(room => { %>
          <li class="card p-pr-16 hover:border-slate-500 transition">
            <a href="/chat/room/<%= room._id %>" class="flex justify-between items-center gap-pr-8">
              <div>
                <p class="text-16sb text-white"><%= room.name || '채팅방' %></p>
                <% if (room.date) { %><p class="text-14m text-slate-400 mt-pr-4">생성일: <%= new Date(room.date).toLocaleString() %></p><% } %>
              </div>
              <span class="text-b-tertiary text-14m">입장하기 →</span>
            </a>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </main>
</body>
</html>
